{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "standard": {
            "format": "%(asctime)s %(levelname)s %(name)s %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S"
        }
    },
    "handlers": {
        "file": {
            "class": "logging.handlers.RotatingFileHandler",
            "formatter": "standard",
            "filename": "/root/autodl-tmp/pxy/share/workspace/logs/vllm.log",
            "maxBytes": 104857600,
            "backupCount": 5,
            "encoding": "utf-8"
        },
        "console": {
            "class": "logging.StreamHandler",
            "formatter": "standard",
            "stream": "ext://sys.stdout"
        }
    },
    "loggers": {
        "vllm": {
            "handlers": ["file", "console"],
            "level": "INFO",
            "propagate": false
        }
    },
    "root": {
        "handlers": ["file", "console"],
        "level": "WARNING"
    }
}
